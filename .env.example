# Database — SQLite for local dev; swap for PostgreSQL in production
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Google APIs (Calendar + Sheets share these credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/callback"

# Uploadthing (https://uploadthing.com)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Resend (https://resend.com)
RESEND_API_KEY=""
# Email address verified in Resend — used as sender
RESEND_FROM_EMAIL="noreply@yoursalon.com"
# Stylist's email — receives booking notifications
STYLIST_EMAIL="stylist@yoursalon.com"

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Admin seed credentials (used by prisma/seed.ts to create the first admin user)
ADMIN_SEED_EMAIL="admin@yoursalon.com"
ADMIN_SEED_PASSWORD="changeme123"
